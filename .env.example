# Variables for `docker compose up` (the full local stack: Postgres + backend + frontend).
# Copy to `.env` in this directory; Docker Compose loads it automatically.
# Every variable has a working default for local use — but JWT_ACCESS_SECRET,
# JWT_REFRESH_SECRET, and OTP_PEPPER MUST be replaced with real random values
# (e.g. `openssl rand -hex 32`) for anything beyond a throwaway local run.

# --- Postgres container ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=case_diary_ai

# --- Backend (case_diary_ai-backend) ---
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
OTP_PEPPER=replace-with-a-long-random-pepper-string
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
CORS_ALLOWED_ORIGINS=http://localhost:5173
COOKIE_SAME_SITE=lax

# --- Frontend build (baked into the static bundle at image-build time) ---
VITE_API_BASE_URL=http://localhost:4000
