# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/case_diary_ai

# JWT signing secrets (use long random strings — never reuse across environments)
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# OTP
OTP_PEPPER=replace-with-a-long-random-pepper-string
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5

# CORS — comma-separated allow-list
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookie behaviour: "lax" for same-parent-domain deployments, "none" only for genuinely cross-site + HTTPS
COOKIE_SAME_SITE=lax

# Email OTP delivery via Resend (optional) — leave blank to keep OTPs console-only.
#   1. Sign up at https://resend.com and create an API key (Dashboard > API Keys).
#   2. Verify a sending domain (Dashboard > Domains) and set EMAIL_FROM to an
#      address on it, e.g. "no-reply@yourdomain.com".
#   3. Without a verified domain you can still test using the default
#      "onboarding@resend.dev" sender, which only delivers to your own account email.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Mobile OTP delivery via WhatsApp (optional) — leave blank to keep OTPs console-only.
# Free Twilio Sandbox, no business verification required:
#   1. Sign up at https://www.twilio.com/try-twilio and open the Console.
#   2. Copy your Account SID and Auth Token from the Console dashboard.
#   3. Go to Messaging > Try it out > Send a WhatsApp message to activate the
#      sandbox, and have each recipient send the shown "join <code>" message
#      to the sandbox number on WhatsApp once.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
